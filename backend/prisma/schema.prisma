generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  PROCTOR
  ADMIN
}

enum RegStatus {
  PENDING
  PAID
  CANCELLED
}

enum AttendanceStatus {
  REGISTERED
  ATTENDED
  ABSENT
}

enum PaymentProvider {
  CLICK
  PAYME
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  phoneNumber   String         @unique
  fullName      String
  role          Role           @default(STUDENT)
  schoolName    String?
  grade         Int?
  region        String?
  district      String?
  parentPhone   String?
  passwordHash  String?
  avatarUrl     String?
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]
  attendances   Attendance[]   @relation("ProctorAttendances")
  createdOlymps Olympiad[]     @relation("CreatedBy")
  updatedOlymps Olympiad[]     @relation("UpdatedBy")
  refreshTokens RefreshToken[]

  @@index([phoneNumber])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
}

model Olympiad {
  id          String         @id @default(uuid())
  title       String
  subject     String
  description String?
  price       Decimal        @db.Decimal(10, 2)
  examDate    DateTime
  regEndDate  DateTime
  isActive    Boolean        @default(true)
  maxSeats    Int?
  maxCapacity Int?        @default(0)
  createdById String?
  createdBy   User?          @relation("CreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?          @relation("UpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  registrations Registration[]
  locations   OlympiadLocation[]

  @@index([subject])
  @@index([examDate])
  @@index([isActive])
}

model OlympiadLocation {
  id          String     @id @default(uuid())
  olympiadId  String
  olympiad    Olympiad   @relation(fields: [olympiadId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  @@unique([olympiadId, locationId])
}

model Location {
  id            String         @id @default(uuid())
  name          String
  address       String
  mapLink       String?
  contactPhone  String?
  contactPerson String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  rooms         Room[]
  registrations Registration[]
  olympiads     OlympiadLocation[]

  @@index([isActive])
}

model Room {
  id            String         @id @default(uuid())
  locationId    String
  location      Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  roomNumber    String
  capacity      Int
  currentSeats  Int            @default(0)
  floor         Int?
  description   String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]

  @@unique([locationId, roomNumber])
  @@index([locationId])
  @@index([isActive])
}

model Registration {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  olympiadId    String
  olympiad      Olympiad       @relation(fields: [olympiadId], references: [id], onDelete: Cascade)
  locationId    String
  location      Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  roomId        String
  room          Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  seatNumber    Int
  status        RegStatus      @default(PENDING)
  paidAt        DateTime?
  lang          String         @default("uz")
  ticketUrl     String?
  qrCodeToken   String         @unique @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  payment       Payment?
  attendance    Attendance?
  result        Result?

  @@unique([olympiadId, roomId, seatNumber])
  @@unique([olympiadId, userId])
  @@index([userId])
  @@index([olympiadId])
  @@index([locationId])
  @@index([roomId])
  @@index([status])
  @@index([qrCodeToken])
}

model Payment {
  id             String         @id @default(uuid())
  registrationId String         @unique
  registration   Registration   @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  provider       PaymentProvider
  transactionId  String         @unique
  amount         Decimal        @db.Decimal(10, 2)
  status         PaymentStatus  @default(PENDING)
  requestId      String?
  payedAt        DateTime?
  cancelledAt    DateTime?
  rawRequest     Json?
  rawResponse    Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([registrationId])
  @@index([transactionId])
  @@index([status])
  @@index([provider])
}

model Attendance {
  id             String            @id @default(uuid())
  registrationId String            @unique
  registration   Registration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  status         AttendanceStatus  @default(REGISTERED)
  proctorId      String?
  proctor        User?             @relation("ProctorAttendances", fields: [proctorId], references: [id])
  scannedAt      DateTime?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([registrationId])
  @@index([proctorId])
  @@index([status])
}

model Result {
  id             String    @id @default(uuid())
  registrationId String    @unique
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  score          Decimal   @db.Decimal(5, 2)
  rank           Int?
  certificateUrl String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([registrationId])
  @@index([rank])
  @@index([score])
}

model Region {
  id        String     @id @default(uuid())
  name      String     @unique
  nameUz    String
  nameRu    String?
  order     Int        @default(0)
  districts District[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model District {
  id        String   @id @default(uuid())
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  name      String
  nameUz    String
  nameRu    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([regionId, name])
  @@index([regionId])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}