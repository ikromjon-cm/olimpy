# ==========================================
# OFFLINE KHISO - BACKEND PRODUCTION ENVIRONMENT
# ==========================================
# Copy this file to .env.docker and fill in your values
# ==========================================

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=production
PORT=3000
API_PREFIX=api
APP_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/offline_khiso?schema=public

# ==========================================
# REDIS
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# JWT (CHANGE THESE! Use: openssl rand -base64 64)
# ==========================================
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# SMS PROVIDER (Eskiz.uz)
# ==========================================
ESKIZ_EMAIL=your-eskiz-email@example.com
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_SENDER_ID=4546
ESKIZ_API_URL=https://notify.eskiz.uz/api

# ==========================================
# PAYMENT PROVIDERS
# ==========================================

# CLICK
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key
CLICK_MERCHANT_USER_ID=your-click-user-id
CLICK_RETURN_URL=https://yourdomain.com/payment/success
CLICK_CANCEL_URL=https://yourdomain.com/payment/cancel
CLICK_API_URL=https://api.click.uz/v2/merchant

# PAYME
PAYME_ID=your-payme-id
PAYME_KEY=your-payme-secret-key
PAYME_ACCOUNT_FIELD=registrationId
PAYME_RETURN_URL=https://yourdomain.com/payment/success
PAYME_CANCEL_URL=https://yourdomain.com/payment/cancel
PAYME_TEST_MODE=true
PAYME_API_URL=https://checkout.test.paycom.uz/api

# ==========================================
# FILE STORAGE (MinIO / S3)
# ==========================================
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=offline-khiso
S3_PUBLIC_URL=https://yourdomain.com/uploads

# ==========================================
# RATE LIMITING
# ==========================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL=60
AUTH_THROTTLE_LIMIT=5

# ==========================================
# OTP SETTINGS
# ==========================================
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_RATE_LIMIT_WINDOW=60
OTP_RATE_LIMIT_MAX=1
OTP_DAILY_LIMIT=5

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png
