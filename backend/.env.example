# ==========================================
# OFFLINE KHISO - BACKEND ENVIRONMENT
# ==========================================

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/offline_khiso?schema=public

# ==========================================
# REDIS
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# JWT
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# SMS PROVIDER (Eskiz.uz)
# ==========================================
ESKIZ_EMAIL=your-eskiz-email@example.com
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_SENDER_ID=4546
ESKIZ_API_URL=https://notify.eskiz.uz/api

# ==========================================
# PAYMENT PROVIDERS
# ==========================================

# CLICK
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key
CLICK_MERCHANT_USER_ID=your-click-user-id
CLICK_RETURN_URL=http://localhost:3001/payment/success
CLICK_CANCEL_URL=http://localhost:3001/payment/cancel
CLICK_API_URL=https://api.click.uz/v2/merchant

# PAYME
PAYME_ID=your-payme-id
PAYME_KEY=your-payme-secret-key
PAYME_ACCOUNT_FIELD=registrationId
PAYME_RETURN_URL=http://localhost:3001/payment/success
PAYME_CANCEL_URL=http://localhost:3001/payment/cancel
PAYME_TEST_MODE=true
PAYME_API_URL=https://checkout.test.paycom.uz/api

# ==========================================
# FILE STORAGE (S3 / MinIO)
# ==========================================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=offline-khiso
S3_PUBLIC_URL=http://localhost:9000/offline-khiso

# ==========================================
# EMAIL (Optional - for admin notifications)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@offline-khiso.uz

# ==========================================
# RATE LIMITING
# ==========================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL=60
AUTH_THROTTLE_LIMIT=5

# ==========================================
# OTP SETTINGS
# ==========================================
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_RATE_LIMIT_WINDOW=60
OTP_RATE_LIMIT_MAX=1
OTP_DAILY_LIMIT=5

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true