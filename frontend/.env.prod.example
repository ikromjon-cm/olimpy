# ==========================================
# OFFLINE KHISO - FRONTEND PRODUCTION ENVIRONMENT
# ==========================================
# Copy this file to .env.docker and fill in your values
# ==========================================

# ==========================================
# API
# ==========================================
# In production behind nginx, use relative path (nginx proxies /api to backend)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_APP_URL=https://yourdomain.com
API_PROXY_TARGET=http://backend:3000

# ==========================================
# APP SETTINGS
# ==========================================
NEXT_PUBLIC_APP_NAME=Olimpiy
NEXT_PUBLIC_APP_DESCRIPTION=Maktab o'quvchilari uchun offlayn olimpiadalar platformasi

# ==========================================
# PAYMENT (Public keys only - safe to commit)
# ==========================================
NEXT_PUBLIC_CLICK_MERCHANT_ID=
NEXT_PUBLIC_PAYME_ID=

# ==========================================
# FEATURE FLAGS
# ==========================================
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
