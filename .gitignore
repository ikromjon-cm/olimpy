docker-data/
data/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Uploads (generated files)
uploads/
backend/uploads/

# Prisma
backend/prisma/migrations/

# Certificates (self-signed SSL)
nginx/ssl/
*.pem
*.key
